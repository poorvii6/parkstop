# ============================================
# ParkStop Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] will crash the app if missing.
# Variables marked [REQUIRED IN PRODUCTION] are optional in dev but fatal in prod.
# Variables marked [RECOMMENDED] will log a warning if missing; features degrade gracefully.
# Variables marked [OPTIONAL] have sensible defaults.

# ------ Server ------
NODE_ENV=development                       # [OPTIONAL] development | production | test
PORT=3000                                  # [OPTIONAL] default: 3000
HOST=0.0.0.0                               # [OPTIONAL] default: 0.0.0.0

# ------ Database ------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/smart_parking   # [REQUIRED]

# ------ Authentication ------
JWT_SECRET=                                # [REQUIRED] min 32 characters
JWT_EXPIRES_IN=7d                          # [OPTIONAL] default: 7d
JWT_REFRESH_SECRET=                        # [OPTIONAL] used for refresh tokens
JWT_REFRESH_EXPIRES_IN=30d                 # [OPTIONAL] default: 30d

# ------ Firebase (Backend — Admin SDK) ------
# Paste the ENTIRE JSON contents of your Firebase service account key file.
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_JSON=             # [REQUIRED IN PRODUCTION]
FIREBASE_SERVER_KEY=                       # [OPTIONAL] legacy FCM server key for push notifications

# ------ Razorpay (Primary Payment Gateway) ------
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=                           # [REQUIRED] starts with rzp_test_ or rzp_live_
RAZORPAY_KEY_SECRET=                       # [REQUIRED]
RAZORPAY_ACCOUNT_NUMBER=                   # [RECOMMENDED] needed for payouts to Spotters

# ------ Redis (Job Queues) ------
# Without this, payouts run INLINE with the request and are NOT retried.
# On Railway: New > Database > Redis, then reference its REDIS_URL here.
REDIS_URL=                                 # [RECOMMENDED] durable payout/notification queues

# ------ Stripe (Secondary Payment Gateway) ------
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=                         # [RECOMMENDED] starts with sk_test_ or sk_live_
STRIPE_WEBHOOK_SECRET=                     # [OPTIONAL] for verifying Stripe webhook signatures

# ------ Cloudinary (Image Uploads) ------
# Get credentials from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=                     # [RECOMMENDED]
CLOUDINARY_API_KEY=                        # [RECOMMENDED]
CLOUDINARY_API_SECRET=                     # [RECOMMENDED]

# ------ Maps ------
# Get key from: https://maps.olakrutrim.com/
OLA_MAPS_API_KEY=                          # [RECOMMENDED] falls back to Nominatim/OSRM without this

# ------ Rate Limiting ------
RATE_LIMIT_WINDOW_MS=900000                # [OPTIONAL] default: 15 minutes (in ms)
RATE_LIMIT_MAX_REQUESTS=100                # [OPTIONAL] default: 100 requests per window
IGNORE_RATE_LIMITS=false                   # [OPTIONAL] set true in dev/testing only

# ------ Pricing Feature Flags ------
ENABLE_TIME_PRICING=false                  # [OPTIONAL] enable time-of-day surge multipliers
ENABLE_LOCATION_PRICING=false              # [OPTIONAL] enable location-type multipliers

# ------ CORS ------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8080   # [OPTIONAL]
SOCKET_CORS_ORIGIN=http://localhost:19000,http://localhost:8081,http://localhost:19006   # [OPTIONAL]

# ------ Logging ------
LOG_LEVEL=info                             # [OPTIONAL] error | warn | info | debug
LOG_FILE_PATH=logs/app.log                 # [OPTIONAL]
