# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/smart_parking

# ===== JWT & AUTH =====
JWT_SECRET=your_super_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d
JWT_ACCESS_SECRET=your_access_secret_key
JWT_REFRESH_SECRET=your_refresh_secret_key

# ===== RAZORPAY =====
RAZORPAY_KEY_ID=rzp_test_xxxxx_or_rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number

# ===== STRIPE =====
STRIPE_SECRET_KEY=sk_test_xxxxx_or_sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===== CLOUDINARY =====
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===== APP CONFIG =====
NODE_ENV=development
PORT=3000
