{
  "name": "smart-parking-backend",
  "version": "2.0.0",
  "description": "Smart Parking Backend API - Production Ready",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npx prisma db push --accept-data-loss && node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node database/migrations/run.js",
    "seed": "node database/seeds/run.js",
    "test": "jest --testPathPatterns=tests/unit --runInBand --forceExit",
    "test:e2e": "node tests/e2e/runner.js"
  },
  "keywords": [
    "parking",
    "api",
    "nodejs",
    "gps",
    "booking"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.1",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jose": "4.15.9",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.3",
    "prisma": "^5.22.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.6.1",
    "stripe": "^22.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "jose": "4.15.9"
  }
}
