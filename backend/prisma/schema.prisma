generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                Int            @id @default(autoincrement())
  user_id           Int?
  spot_id           Int?
  start_time        DateTime       @db.Timestamp(6)
  end_time          DateTime?      @db.Timestamp(6)
  status            String?        @default("active") @db.VarChar(20)
  total_price       Decimal?       @db.Decimal(10, 2)
  created_at        DateTime?      @default(now()) @db.Timestamp(6)
  hours             Decimal        @default(1) @db.Decimal
  otp_code          String?        @db.VarChar(10)
  otp_expires_at    DateTime?      @db.Timestamp(6)
  updated_at        DateTime?      @default(now()) @db.Timestamp(6)
  actual_end_time   DateTime?      @db.Timestamp(6)
  otp_attempts      Int?           @default(0)
  platform_fee      Decimal?       @default(0) @db.Decimal(10, 2)
  spotter_earning   Decimal?       @default(0) @db.Decimal(10, 2)
  vehicle_type      String?        @default("car") @db.VarChar(20)
  vehicle_subtype   String?        @db.VarChar(50)
  payment_id        String?        @db.VarChar(100)
  payment_method_id Int?
  payment_status    String?        @default("pending") @db.VarChar(20)
  payment_mode      String?        @default("online") @db.VarChar(20)
  checkout_otp      String?        @db.VarChar(10)
  slot_name         String?        @db.VarChar(50)
  parking_spots     parking_spots? @relation(fields: [spot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review            reviews?
  dispute           disputes?

  @@index([user_id])
  @@index([spot_id])
  @@index([status])
  @@index([spot_id, status])
  @@index([user_id, status])
  @@index([created_at])
}

model locations {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  latitude   Decimal?  @db.Decimal(10, 8)
  longitude  Decimal?  @db.Decimal(11, 8)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model parking_spots {
  id              Int        @id @default(autoincrement())
  spotter_id      Int?
  title           String     @db.VarChar(100)
  description     String?
  price_per_hour  Decimal    @db.Decimal(10, 2)
  latitude        Decimal?   @db.Decimal(10, 8)
  longitude       Decimal?   @db.Decimal(11, 8)
  is_available    Boolean?   @default(true)
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  address         String?
  base_price      Decimal?   @db.Decimal
  total_slots     Int?       @default(1)
  available_slots Int?       @default(1)
  location_type   String?    @db.VarChar(20)
  is_active       Boolean?   @default(true)
  updated_at      DateTime?  @default(now()) @db.Timestamp(6)
  amenities       Json?      @default("[]")
  bike_slots      Int?       @default(0)
  car_slots       Int?       @default(1)
  images          Json?      @default("[]")
  slot_names      Json?      @default("[]")
  bookings        bookings[]
  saved_spots     saved_spots[]
  users           users?     @relation(fields: [spotter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews         reviews[]

  @@index([spotter_id])
  @@index([is_active])
  @@index([is_available])
  @@index([latitude, longitude])
  @@index([location_type])
}

model payment_methods {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  provider           String   @db.VarChar(50)
  provider_method_id String   @db.VarChar(255)
  method_type        String   @db.VarChar(20)
  last4              String?  @db.VarChar(4)
  brand              String?  @db.VarChar(50)
  is_default         Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamp(6)
  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                    Int               @id @default(autoincrement())
  name                  String            @db.VarChar(100)
  email                 String            @unique @db.VarChar(150)
  password              String
  role                  String            @db.VarChar(20)
  created_at            DateTime?         @default(now()) @db.Timestamp(6)
  phone                 String?           @db.VarChar(20)
  refresh_token         String?
  refresh_token_expires DateTime?         @db.Timestamp(6)
  full_name             String?           @db.VarChar(255)
  stripe_account_id     String?           @db.VarChar(255)
  payout_provider       String?           @default("stripe") @db.VarChar(20)
  push_token            String?
  updated_at            DateTime?         @default(now()) @db.Timestamp(6)
  balance               Decimal           @default(0) @db.Decimal(10, 2)
  address               String?           @db.VarChar(255)
  dob                   String?           @db.VarChar(20)
  // Payout fields for Spotters
  upi_id                    String?           @db.VarChar(50)
  bank_account_number       String?           @db.VarChar(20)
  bank_ifsc                 String?           @db.VarChar(15)
  bank_account_name         String?           @db.VarChar(100)
  razorpay_contact_id       String?           @db.VarChar(50)
  razorpay_fund_account_id  String?           @db.VarChar(50)
  payout_mode               String?           @default("upi") @db.VarChar(20)

  bookings              bookings[]
  locations             locations[]
  parking_spots         parking_spots[]
  payment_methods       payment_methods[]
  withdrawals           withdrawals[]
  saved_spots           saved_spots[]
  payouts               payouts[]
  reviews_given         reviews[]         @relation("reviewer")
  reviews_received      reviews[]         @relation("spotter_reviews")
  disputes              disputes[]

  @@index([email])
  @@index([role])
  @@index([push_token])
}

model payouts {
  id                 Int       @id @default(autoincrement())
  user_id            Int
  booking_id         Int?
  amount             Decimal   @db.Decimal(10, 2)
  razorpay_payout_id String?   @db.VarChar(100)
  status             String    @default("pending") @db.VarChar(20)
  mode               String    @default("UPI") @db.VarChar(20)
  purpose            String?   @default("payout") @db.VarChar(50)
  narration          String?
  failure_reason     String?
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([booking_id])
  @@index([status])
}

model withdrawals {
  id                Int      @id @default(autoincrement())
  user_id           Int
  amount            Decimal  @db.Decimal(10, 2)
  payment_method_id Int
  status            String   @default("pending") @db.VarChar(20)
  created_at        DateTime @default(now()) @db.Timestamp(6)
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model saved_spots {
  id              Int           @id @default(autoincrement())
  user_id         Int
  spot_id         Int
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  parking_spots   parking_spots @relation(fields: [spot_id], references: [id], onDelete: Cascade)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, spot_id])
}

model reviews {
  id          Int      @id @default(autoincrement())
  booking_id  Int      @unique          // one review per booking
  reviewer_id Int                       // Finder's user ID
  spotter_id  Int                       // Spotter's user ID
  spot_id     Int
  rating      Int                       // 1-5
  comment     String?  @db.Text
  created_at  DateTime @default(now())

  bookings      bookings      @relation(fields: [booking_id], references: [id])
  reviewer      users         @relation("reviewer", fields: [reviewer_id], references: [id])
  spotter       users         @relation("spotter_reviews", fields: [spotter_id], references: [id])
  parking_spots parking_spots @relation(fields: [spot_id], references: [id])

  @@index([spotter_id])
  @@index([spot_id])
}

model disputes {
  id          Int      @id @default(autoincrement())
  booking_id  Int      @unique          // one dispute per booking
  raised_by   Int
  reason      String   @db.VarChar(100)
  description String?  @db.Text
  status      String   @default("open") @db.VarChar(20)
  resolution  String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  bookings    bookings @relation(fields: [booking_id], references: [id])
  user        users    @relation(fields: [raised_by], references: [id])

  @@index([status])
  @@index([booking_id])
}
