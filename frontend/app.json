{
  "expo": {
    "name": "Smart Parking",
    "slug": "smart-parking",
    "scheme": "smart-parking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartparking.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.smartparking.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Smart Parking to use your location for navigating to available spots in the background."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Smart Parking to access your camera to take spot photos.",
          "photosPermission": "Allow Smart Parking to access your photos to upload spot pictures."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "com.smartparking.app",
          "enableGooglePay": true
        }
      ],
      "expo-font"
    ]
  }
}
